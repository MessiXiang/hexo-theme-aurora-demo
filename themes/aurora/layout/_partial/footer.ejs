<footer class="aurora-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
        <%= theme.logo_text || config.title %>
      </span>
      <% if (theme.footer.custom_text) { %>
        <p class="footer-motto"><%= theme.footer.custom_text %></p>
      <% } %>
    </div>

    <div class="footer-nav">
      <% for (var name in theme.menu) { %>
        <% if (name !== 'Search') { %>
          <a href="<%- url_for(theme.menu[name]) %>"><%= name %></a>
        <% } %>
      <% } %>
    </div>

    <div class="footer-meta">
      <% if (theme.footer.since) { %>
        <span>&copy; <%= theme.footer.since %> - <%= new Date().getFullYear() %></span>
      <% } %>
      <% if (theme.footer.powered) { %>
        <span>Powered by <a href="https://hexo.io" target="_blank" rel="noopener">Hexo</a> &middot; Theme Aurora</span>
      <% } %>
    </div>
  </div>
</footer>
